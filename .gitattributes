# Normaliza quebras de linha no repositorio (LF), preservando binarios.
* text=auto eol=lf

# Scripts que precisam de CRLF no Windows
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binarios — nunca normalizar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.lockb binary
*.jks   binary
*.keystore binary
*.p12   binary
