{
  "cli": { 
    "version": ">= 16.4.0", 
    "appVersionSource": "remote" 
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"    
      },
      "ios": {
        "simulator": false   
      }
    },
    "productionAAB": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      }
    }
  },
  "submit": { "production": {} }
}
