# Supabase
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>
VITE_SUPABASE_PROJECT_ID=<project-id>

# Site
VITE_SITE_URL=https://<your-domain.com>

# App Mobile (opcional)
VITE_PLAY_STORE_LINK=https://play.google.com/store/apps/details?id=...
VITE_APK_URL=https://...

# API de personalização (TraiUp backend)
VITE_APITRAIUP_URL=http://localhost:8000

# Supabase Edge Function — IA (NÃO expor no frontend)
# Obter chave em: https://aistudio.google.com/apikey (gratuito, sem cartão)
# Configurar via: supabase secrets set GEMINI_API_KEY=AIza...
# GEMINI_API_KEY=AIza...
