# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Servidor (opcionais)
# PORT=3000
# JSON_LIMIT=50mb
# NODE_ENV=production
# SHUTDOWN_TIMEOUT_MS=30000
# API_ONLY=true              # pula setup de SPA (Vite/dist) — só endpoints /api/*
                             # ou use `npm run dev:api` (detecta automaticamente)
# Validação / SSRF / abuso
# ALLOW_PRIVATE_FONTE_URLS=true  # permite fontes apontando para localhost/RFC1918
                                # NUNCA em produção (default: false)
# MAX_FONTE_SIZE_MB=100          # tamanho máximo por fonte baixada (default 100MB)
# FONTE_FETCH_TIMEOUT_MS=30000   # timeout por download de fonte
# RATE_WINDOW_MS=60000           # janela do rate limiter (default 60s)
# RATE_MAX=30                    # max requests por IP por janela (default 30/min)

# Logging
# LOG_LEVEL=info             # debug | info | warn | error
# LOG_FORMAT=pretty          # pretty (dev) | json (prod) — default segue NODE_ENV

# MAX_JOB_DURATION_MS=900000  # timeout duro do job (15min default)
# HEARTBEAT_INTERVAL_MS=30000 # heartbeat atualiza updated_at a cada 30s (default)
# STALE_JOB_THRESHOLD_MS=150000 # jobs sem heartbeat há > isto = órfãos (default 5x heartbeat = 2.5min)

# Segurança (recomendado em produção)
# API_SHARED_SECRET=                 # header: x-api-secret ou Authorization: Bearer <secret>
# CORS_ORIGIN=https://trailup.app    # CSV, sem env libera tudo
